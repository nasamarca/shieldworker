# ══════════════════════════════════════════════════════════════════════
#  ShieldWorker — Smart Contract Environment Variables
#  Copy this file to .env and fill in the values
#  NEVER commit .env to git!
# ══════════════════════════════════════════════════════════════════════

# ── Deployer Wallet ──────────────────────────────────────────────────
# Private key of the wallet that will deploy contracts and act as admin
# Must have Fuji AVAX for gas (get from: https://faucet.avax.network)
PRIVATE_KEY=

# ── RPC ──────────────────────────────────────────────────────────────
# Avalanche Fuji testnet RPC URL
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ── Contract Verification (optional) ─────────────────────────────────
# Snowtrace API key for contract verification on Fuji explorer
SNOWTRACE_API_KEY=

# ── x402 Relayer Wallet ──────────────────────────────────────────────
# Address of the Thirdweb Server Wallet that acts as x402 relayer
# This wallet calls ProtectionPool.contributeFor() after x402 settlement
# Get from: Thirdweb Dashboard → Project → Wallets → Server Wallets
RELAYER_WALLET=

# ── Pool Seeding (optional) ──────────────────────────────────────────
# Amount of Fuji USDC to seed the pool at deploy time (6 decimals)
# e.g., 200000000 = 200 USDC
# Set to 0 to skip seeding during deployment
SEED_AMOUNT=0
